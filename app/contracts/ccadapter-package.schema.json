{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-theme.local/contracts/ccadapter-package.schema.json",
  "title": "CC Theme .ccadapter package manifest",
  "description": "The adapter.json manifest stored at the root of a deterministic ZIP-compatible .ccadapter archive.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schemaVersion",
    "adapterId",
    "adapterVersion",
    "adapterReleaseRevision",
    "assetIdentity",
    "platform",
    "architecture",
    "contracts",
    "files"
  ],
  "properties": {
    "kind": { "const": "cc-theme.adapter-package" },
    "schemaVersion": { "const": 1 },
    "adapterId": { "$ref": "#/$defs/adapterId" },
    "adapterVersion": { "$ref": "#/$defs/semver" },
    "adapterReleaseRevision": { "type": "integer", "minimum": 1 },
    "assetIdentity": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)+-[0-9]+\\.[0-9]+\\.[0-9]+-r[1-9][0-9]*-(?:macos|windows)-(?:arm64|x86_64|universal2)$",
      "maxLength": 200
    },
    "platform": { "enum": ["macos", "windows"] },
    "architecture": { "enum": ["arm64", "x86_64", "universal2"] },
    "contracts": { "$ref": "#/$defs/contracts" },
    "files": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": { "$ref": "#/$defs/file" }
    }
  },
  "$defs": {
    "adapterId": {
      "type": "string",
      "pattern": "^(?!.*-skin(?:-|$))[a-z0-9]+(?:-[a-z0-9]+)+$",
      "minLength": 3,
      "maxLength": 80
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-(?:0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*))*)?$",
      "maxLength": 80
    },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimumManagerVersion",
        "capabilityVersion",
        "unifiedThemeSchemaVersion",
        "adapterPackageSchemaVersion"
      ],
      "properties": {
        "minimumManagerVersion": { "$ref": "#/$defs/semver" },
        "capabilityVersion": { "$ref": "#/$defs/semver" },
        "unifiedThemeSchemaVersion": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "adapterPackageSchemaVersion": { "const": 1 }
      }
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "bytes", "sha256", "mode"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^payload/[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$",
          "maxLength": 512
        },
        "bytes": { "type": "integer", "minimum": 1, "maximum": 8388608 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "mode": { "enum": [420, 493] }
      }
    }
  }
}
