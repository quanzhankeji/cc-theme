{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-theme.local/contracts/adapter-request.schema.json",
  "title": "CC Theme desktop adapter request",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "requestId", "adapter", "operation"],
  "properties": {
    "kind": { "const": "cc-theme.adapter-request" },
    "schemaVersion": { "const": 1 },
    "requestId": { "type": "string", "pattern": "^[A-Za-z0-9_-]{8,80}$" },
    "adapter": { "enum": ["mac-codex", "mac-doubao", "mac-workbuddy"] },
    "operation": { "enum": ["detect", "preflight", "install", "apply", "launch", "apply-and-launch", "verify", "pause", "restore"] },
    "themeFamilyId": { "type": "string", "pattern": "^[A-Za-z0-9_-]{1,80}$" },
    "themeId": { "type": "string", "pattern": "^[A-Za-z0-9_-]{1,80}$" },
    "options": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requireLive": { "type": "boolean" },
        "restart": { "type": "boolean" },
        "restoreBaseTheme": { "type": "boolean" },
        "uninstall": { "type": "boolean" },
        "port": { "type": "integer", "minimum": 1024, "maximum": 65535 }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "operation": { "enum": ["install"] } }, "required": ["operation"] },
      "then": { "required": ["themeFamilyId"] }
    },
    {
      "if": { "properties": { "operation": { "enum": ["apply", "apply-and-launch"] } }, "required": ["operation"] },
      "then": { "required": ["themeId"] }
    }
  ]
}
