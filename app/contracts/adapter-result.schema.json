{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-theme.local/contracts/adapter-result.schema.json",
  "title": "CC Theme desktop adapter result",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "requestId", "adapter", "operation", "phase", "status", "ok", "changed", "code", "message", "timestamp", "durationMs"],
  "properties": {
    "kind": { "const": "cc-theme.adapter-result" },
    "schemaVersion": { "const": 1 },
    "requestId": { "type": "string", "pattern": "^[A-Za-z0-9_-]{8,80}$" },
    "adapter": { "enum": ["mac-codex", "mac-workbuddy"] },
    "operation": { "enum": ["detect", "preflight", "install", "apply", "launch", "apply-and-launch", "verify", "pause", "restore"] },
    "phase": { "enum": ["detect", "preflight", "stage", "install", "apply", "launch", "verify", "cleanup", "complete"] },
    "status": { "enum": ["success", "failed", "partial", "skipped"] },
    "ok": { "type": "boolean" },
    "changed": { "type": "boolean" },
    "code": { "enum": ["ok", "invalid-request", "app-not-found", "client-version-unsupported", "runtime-invalid", "theme-invalid", "adapter-landmark-missing", "transport-unavailable", "install-failed", "apply-failed", "launch-failed", "verification-failed", "cleanup-incomplete", "operation-cancelled", "unexpected-failure"] },
    "message": { "type": "string", "minLength": 1, "maxLength": 320 },
    "timestamp": { "type": "string", "format": "date-time" },
    "durationMs": { "type": "integer", "minimum": 0 },
    "details": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "application": { "enum": ["codex", "workbuddy"] },
        "clientVersion": { "type": "string", "maxLength": 80 },
        "themeFamilyId": { "type": "string", "pattern": "^[A-Za-z0-9_-]{1,80}$" },
        "themeId": { "type": "string", "pattern": "^[A-Za-z0-9_-]{1,80}$" },
        "processRunning": { "type": "boolean" },
        "transportAvailable": { "type": "boolean" },
        "verification": { "enum": ["not-run", "passed", "failed"] },
        "warnings": { "type": "array", "maxItems": 20, "items": { "type": "string", "minLength": 1, "maxLength": 240 } }
      }
    }
  },
  "allOf": [
    { "if": { "properties": { "status": { "const": "success" } }, "required": ["status"] }, "then": { "properties": { "ok": { "const": true }, "code": { "const": "ok" } } } },
    { "if": { "properties": { "status": { "const": "failed" } }, "required": ["status"] }, "then": { "properties": { "ok": { "const": false } }, "not": { "properties": { "code": { "const": "ok" } }, "required": ["code"] } } }
  ]
}
