{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-theme.local/contracts/adapter-capability.schema.json",
  "title": "CC Theme normalized Adapter capability discovery result",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "adapterId", "availability", "capabilityVersion", "compileAvailable", "runtimeApplyAvailable", "sharedCore", "targetProfile", "presentationProfiles", "localRuntimeOverrides", "compatibility", "projection", "sourceCapabilityFile", "raw"],
  "properties": {
    "kind": { "const": "cc-theme.normalized-adapter-capability" },
    "schemaVersion": { "const": 1 },
    "adapterId": { "$ref": "#/$defs/adapterId" },
    "displayName": { "type": "string", "minLength": 1, "maxLength": 80 },
    "availability": { "enum": ["available", "projection-only", "unavailable"] },
    "capabilityVersion": { "type": "string", "minLength": 1, "maxLength": 40 },
    "compileAvailable": { "type": "boolean" },
    "runtimeApplyAvailable": { "type": "boolean" },
    "sharedCore": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sourceToken", "support", "required", "targetPath", "diagnostic"],
        "properties": {
          "sourceToken": { "type": "string", "minLength": 1, "maxLength": 200 },
          "support": { "enum": ["supported", "approximated", "unsupported"] },
          "required": { "type": "boolean" },
          "targetPath": { "type": ["string", "null"], "maxLength": 200 },
          "diagnostic": { "type": "string", "minLength": 1, "maxLength": 240 }
        }
      }
    },
    "targetProfile": { "type": "object" },
    "presentationProfiles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["profileVersion", "geometryPolicy", "surfaces"],
        "properties": {
          "profileVersion": { "type": "integer", "minimum": 1 },
          "geometryPolicy": { "enum": ["scene-bounded"] },
          "surfaces": {
            "type": "object",
            "additionalProperties": false,
            "required": ["shell", "navigation", "home", "conversation", "composer", "cards", "overlays"],
            "properties": {
              "shell": { "enum": ["exact", "approximated", "unsupported"] },
              "navigation": { "enum": ["exact", "approximated", "unsupported"] },
              "home": { "enum": ["exact", "approximated", "unsupported"] },
              "conversation": { "enum": ["exact", "approximated", "unsupported"] },
              "composer": { "enum": ["exact", "approximated", "unsupported"] },
              "cards": { "enum": ["exact", "approximated", "unsupported"] },
              "overlays": { "enum": ["exact", "approximated", "unsupported"] }
            }
          }
        }
      }
    },
    "localRuntimeOverrides": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stableTokenIds", "baseHashAvailable", "serialTransactionSeamAvailable", "incompatiblePolicy"],
      "properties": {
        "stableTokenIds": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
        "baseHashAvailable": { "type": "boolean" },
        "serialTransactionSeamAvailable": { "type": "boolean" },
        "incompatiblePolicy": { "type": "string", "minLength": 1, "maxLength": 160 }
      }
    },
    "compatibility": { "type": "object" },
    "projection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["module", "export", "requestContract", "outputDirectory"],
      "properties": {
        "module": { "type": ["string", "null"] },
        "export": { "type": ["string", "null"] },
        "requestContract": { "type": ["string", "null"] },
        "outputDirectory": { "type": ["string", "null"] }
      }
    },
    "sourceCapabilityFile": { "type": "string", "minLength": 1 },
    "raw": { "type": "object" }
  },
  "$defs": {
    "adapterId": { "enum": ["mac-codex", "mac-doubao", "mac-workbuddy"] }
  }
}
