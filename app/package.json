{
  "name": "cc-theme",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "prepare:resources": "node scripts/prepare-runtime-resources.mjs",
    "prepare:runtime": "bash scripts/prepare-node-runtime.sh",
    "adapter:catalog:check": "node scripts/generate-adapter-version-catalog.mjs --check",
    "adapter:build": "node scripts/build-adapter-packages.mjs",
    "tauri:dev": "npm run prepare:runtime && tauri dev",
    "tauri:build": "npm run prepare:runtime && tauri build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "test:node": "npm run prepare:resources && node --test tests/*.test.mjs",
    "test:ui": "vitest run",
    "test": "npm run test:node && npm run test:ui",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^27.0.0",
    "typescript": "~5.9.3",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}
