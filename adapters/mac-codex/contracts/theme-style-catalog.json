{
  "kind": "theme.style-catalog",
  "revision": 1,
  "catalogId": "mac-codex-theme",
  "geometryPolicy": "native",
  "description": "The single allowlisted style and bounded runtime-control interface shared by the Mac Codex runtime and its local editor.",
  "surfaceContexts": ["home", "task", "library", "settings"],
  "groups": [
    { "id": "foundation", "labelZhCN": "基础表面", "labelEn": "Foundation" },
    { "id": "text", "labelZhCN": "文字与图标", "labelEn": "Text and icons" },
    { "id": "navigation", "labelZhCN": "侧边栏与导航", "labelEn": "Navigation" },
    { "id": "content", "labelZhCN": "内容与对话", "labelEn": "Content" },
    { "id": "composer", "labelZhCN": "输入框", "labelEn": "Composer" },
    { "id": "interaction", "labelZhCN": "交互与状态", "labelEn": "Interaction and status" },
    { "id": "border", "labelZhCN": "边框与焦点", "labelEn": "Borders and focus" },
    { "id": "typography", "labelZhCN": "字体", "labelEn": "Typography" }
  ],
  "roleFamilies": [
    {
      "id": "shell",
      "labelZhCN": "窗口与主壳",
      "roles": ["header", "sidebar", "main-content", "main-top-fade"]
    },
    {
      "id": "home",
      "labelZhCN": "主页与新对话",
      "roles": ["home-hero", "home-heading", "home-icon", "home-suggestions", "home-suggestions-grid", "home-suggestion-card", "home-suggestion-icon", "home-suggestion-label"]
    },
    {
      "id": "conversation",
      "labelZhCN": "对话与输入",
      "roles": ["composer-root", "composer", "send-button", "model-picker", "model-picker-popup", "model-power-slider", "writing-block-surface", "response-waiting-indicator", "history-preview-surface", "history-preview-card"]
    },
    {
      "id": "library",
      "labelZhCN": "Sites、Scheduled 与 Plugins",
      "roles": ["library-shell", "library-search-header", "library-search", "library-search-input"]
    },
    {
      "id": "settings",
      "labelZhCN": "设置",
      "roles": ["settings-shell", "settings-sidebar", "settings-nav", "settings-nav-item", "settings-content", "settings-section", "settings-search", "settings-search-input", "settings-group", "settings-row", "settings-control", "settings-input", "settings-select", "settings-checkbox", "settings-radio", "settings-radio-group", "settings-switch"]
    },
    {
      "id": "overlay",
      "labelZhCN": "弹窗与浮层",
      "roles": ["overlay-surface"],
      "variants": ["dialog", "menu", "listbox", "tooltip", "status", "alert"]
    },
    {
      "id": "bottom-panel",
      "labelZhCN": "底部面板与终端",
      "roles": ["bottom-panel-shell", "bottom-panel-surface", "bottom-panel-header", "bottom-panel-tablist", "bottom-panel-tab", "bottom-panel-body", "bottom-panel-sash", "bottom-panel-terminal-shell", "bottom-panel-terminal-padding", "bottom-panel-terminal", "bottom-panel-terminal-viewport", "bottom-panel-terminal-screen"]
    }
  ],
  "nativeRoles": [
    {
      "id": "settings-switch",
      "reason": "Preserve the host switch track, thumb, states and geometry."
    },
    {
      "id": "browser-webview",
      "reason": "A browser WebView remains host-owned and must never be covered or recolored by CC Theme."
    }
  ],
  "adapterBindingFamilies": ["--color-*", "--vscode-*", "--oai-*"],
  "runtimeControls": [
    {
      "id": "background.presentation",
      "type": "enum",
      "values": ["playing", "paused", "disabled", "enabled", "static"],
      "persistence": "theme-runtime-overrides",
      "reducedMotionOwner": "client-runtime"
    }
  ],
  "runtimeOnlyVariables": [
    "--skin-active-art",
    "--skin-art",
    "--skin-art-focus-x",
    "--skin-art-focus-y",
    "--skin-art-position",
    "--skin-backdrop-blur",
    "--skin-backdrop-saturation",
    "--skin-focus-x",
    "--skin-focus-y",
    "--skin-hero-art",
    "--skin-hero-position",
    "--skin-home-card-accent",
    "--skin-ink-soft",
    "--skin-interactive-scrim-opacity",
    "--skin-motion-duration",
    "--skin-name",
    "--skin-native-canvas",
    "--skin-native-sidebar",
    "--skin-particles-opacity",
    "--skin-project-label",
    "--skin-project-prefix",
    "--skin-radius-card",
    "--skin-radius-control",
    "--skin-radius-panel",
    "--skin-radius-scale",
    "--skin-tagline",
    "--skin-video-position",
    "--skin-video-scrim-color",
    "--skin-video-scrim-opacity"
  ],
