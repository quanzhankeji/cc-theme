    { "id": "foundation.panelRaised", "labelZhCN": "次级面板", "labelEn": "Raised panel", "group": "foundation", "type": "color", "themePath": "colors.panelAlt", "cssVariable": "--skin-panel-2", "roles": ["settings-group", "library-search"] },
    { "id": "foundation.surfaceBase", "labelZhCN": "主内容表面", "labelEn": "Base surface", "group": "content", "type": "color", "themePath": "semanticColors.surfaceBase", "cssVariable": "--skin-surface-base", "roles": ["main-content", "settings-content", "library-shell"] },
    { "id": "foundation.surfaceRaised", "labelZhCN": "控件表面", "labelEn": "Raised surface", "group": "content", "type": "color", "themePath": "semanticColors.surfaceRaised", "cssVariable": "--skin-surface-raised", "roles": ["settings-search", "settings-row", "library-search"] },
    { "id": "foundation.surfaceElevated", "labelZhCN": "弹窗表面", "labelEn": "Elevated surface", "group": "content", "type": "color", "themePath": "semanticColors.surfaceElevated", "cssVariable": "--skin-surface-elevated", "roles": ["overlay-surface", "model-picker-popup", "history-preview-card"] },
