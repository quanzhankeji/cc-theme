    { "id": "navigation.header", "labelZhCN": "顶部栏表面", "labelEn": "Header surface", "group": "navigation", "type": "color", "themePath": "semanticColors.headerSurface", "cssVariable": "--skin-header-surface", "roles": ["header", "bottom-panel-header"] },
