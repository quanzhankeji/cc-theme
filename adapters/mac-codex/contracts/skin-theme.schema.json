{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/quanzhankeji/cc-theme/main/adapters/mac-codex/contracts/skin-theme.schema.json",
  "title": "Skin Theme",
  "description": "The single allowlisted theme contract consumed by Skin adapters and runtimes.",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "id", "name", "image"],
  "allOf": [
    {
      "not": {
        "required": ["backgroundVideo", "interactiveBackground"]
      }
    }
  ],
  "properties": {
    "kind": { "const": "skin.theme" },
    "id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{1,80}$" },
    "name": { "type": "string", "minLength": 1, "maxLength": 80 },
    "brandSubtitle": { "type": "string", "maxLength": 80 },
    "tagline": { "type": "string", "maxLength": 160 },
    "projectPrefix": { "type": "string", "maxLength": 80 },
    "projectLabel": { "type": "string", "maxLength": 80 },
    "statusText": { "type": "string", "maxLength": 80 },
    "quote": { "type": "string", "maxLength": 80 },
    "image": { "$ref": "#/$defs/imageFile" },
    "homeHeroImage": { "$ref": "#/$defs/imageFile" },
    "backgroundVideo": { "$ref": "#/$defs/videoFile" },
    "interactiveBackground": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": { "const": "ripple" },
            "intensity": { "type": "number", "minimum": 0, "maximum": 1 },
            "radiusPx": { "type": "number", "minimum": 8, "maximum": 96 },
            "quality": { "enum": ["auto", "low", "high"] },
            "scrimOpacity": { "type": "number", "minimum": 0, "maximum": 0.8 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "atlas", "directions", "columns", "rows"],
          "properties": {
            "type": { "const": "directional" },
            "atlas": { "$ref": "#/$defs/staticWebpFile" },
            "directions": { "enum": [8, 16, 32] },
            "columns": { "type": "integer", "minimum": 1, "maximum": 8 },
            "rows": { "type": "integer", "minimum": 1, "maximum": 8 },
            "firstDirectionDegrees": { "type": "number", "minimum": -180, "maximum": 180 },
            "idleFrame": { "type": "integer", "minimum": 0, "maximum": 31 },
            "origin": { "$ref": "#/$defs/position" },
            "scrimOpacity": { "type": "number", "minimum": 0, "maximum": 0.8 }
          }
        }
      ]
    },
    "pet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest", "spritesheet"],
      "properties": {
        "manifest": { "const": "pet/pet.json" },
        "spritesheet": { "const": "pet/spritesheet.webp" },
        "installPolicy": { "const": "if-absent" },
        "selectionPolicy": { "const": "manual" }
      }
    },
    "colors": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "background": { "$ref": "#/$defs/color" },
        "panel": { "$ref": "#/$defs/color" },
        "panelAlt": { "$ref": "#/$defs/color" },
        "accent": { "$ref": "#/$defs/color" },
        "accentAlt": { "$ref": "#/$defs/color" },
        "secondary": { "$ref": "#/$defs/color" },
        "highlight": { "$ref": "#/$defs/color" },
        "text": { "$ref": "#/$defs/color" },
        "muted": { "$ref": "#/$defs/color" },
        "line": { "$ref": "#/$defs/color" }
      }
    },
    "semanticColors": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "surfaceBase": { "$ref": "#/$defs/color" },
        "surfaceRaised": { "$ref": "#/$defs/color" },
        "surfaceElevated": { "$ref": "#/$defs/color" },
        "surfaceCode": { "$ref": "#/$defs/color" },
        "textStrong": { "$ref": "#/$defs/color" },
        "placeholder": { "$ref": "#/$defs/color" },
        "borderSubtle": { "$ref": "#/$defs/color" },
        "borderDefault": { "$ref": "#/$defs/color" },
        "borderStrong": { "$ref": "#/$defs/color" },
        "action": { "$ref": "#/$defs/color" },
        "actionHover": { "$ref": "#/$defs/color" },
        "actionPressed": { "$ref": "#/$defs/color" },
        "actionForeground": { "$ref": "#/$defs/color" },
        "hoverSurface": { "$ref": "#/$defs/color" },
        "pressedSurface": { "$ref": "#/$defs/color" },
        "selectedSurface": { "$ref": "#/$defs/color" },
        "selectedHoverSurface": { "$ref": "#/$defs/color" },
        "focusRing": { "$ref": "#/$defs/color" },
        "link": { "$ref": "#/$defs/color" },
        "danger": { "$ref": "#/$defs/color" },
        "success": { "$ref": "#/$defs/color" },
        "warning": { "$ref": "#/$defs/color" },
        "sidebarSurface": { "$ref": "#/$defs/color" },
        "headerSurface": { "$ref": "#/$defs/color" },
        "mainScrimStart": { "$ref": "#/$defs/color" },
        "mainScrimMid": { "$ref": "#/$defs/color" },
        "mainScrimEnd": { "$ref": "#/$defs/color" },
        "composerSurface": { "$ref": "#/$defs/color" }
      }
    },
    "fonts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ui": { "$ref": "#/$defs/fontList" },
        "display": { "$ref": "#/$defs/fontList" },
        "code": { "$ref": "#/$defs/fontList" }
      }
    },
    "art": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "analysis": { "enum": ["auto", "off"] },
        "focusX": { "$ref": "#/$defs/unit" },
        "focusY": { "$ref": "#/$defs/unit" },
        "safeArea": { "enum": ["auto", "left", "right", "center", "none"] },
        "taskMode": { "enum": ["auto", "ambient", "banner", "off"] },
        "paletteMode": { "enum": ["system", "media"] },
        "adaptivePalette": { "type": "boolean" }
      }
    },
    "appearance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "shellMode": { "enum": ["auto", "light", "dark"] },
        "newTaskLayout": { "enum": ["cards", "banner"] },
        "backgroundVideoPosterMode": { "enum": ["none", "image"] },
        "backgroundVideoScrimOpacity": { "type": "number", "minimum": 0, "maximum": 0.8 },
        "backgroundPosition": { "$ref": "#/$defs/position" },
        "homeHeroPosition": { "$ref": "#/$defs/position" },
        "backgroundVideoPosition": { "$ref": "#/$defs/position" },
        "backdropBlurPx": { "type": "number", "minimum": 0, "maximum": 48 },
        "backdropSaturation": { "type": "number", "minimum": 0.5, "maximum": 1.5 },
        "radiusScale": { "type": "number", "minimum": 0.75, "maximum": 1.5 },
        "reduceParticles": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "color": {
      "type": "string",
      "pattern": "^(#[0-9A-Fa-f]{6}|rgba?\\([0-9., %]+\\))$"
    },
    "imageFile": {
      "type": "string",
      "pattern": "^[^/\\\\]+\\.(png|jpe?g|webp)$"
    },
    "videoFile": {
      "type": "string",
      "pattern": "^[^/\\\\]+\\.mp4$"
    },
    "staticWebpFile": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+\\.webp$"
    },
    "fontList": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": { "type": "string", "minLength": 1, "maxLength": 80 }
    },
    "unit": { "type": "number", "minimum": 0, "maximum": 1 },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["xPercent", "yPercent"],
      "properties": {
        "xPercent": { "type": "number", "minimum": 0, "maximum": 100 },
        "yPercent": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    }
  }
}
