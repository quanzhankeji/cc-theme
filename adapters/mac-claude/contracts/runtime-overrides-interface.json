{
  "kind": "cc-theme.runtime-overrides-interface",
  "schemaVersion": 1,
  "adapterId": "mac-claude",
  "precedence": ["shared-core", "target-profile", "local-runtime-overrides", "runtime-accessibility-and-host-safety"],
  "recordKind": "theme.runtime-style-overrides",
  "stableTokenSource": "contracts/theme-style-catalog.json",
  "binding": ["themeId", "baseThemeSha256"],
  "baseChangePolicy": {
    "compatible": "validate-rebase-replay-with-visible-diagnostic",
    "incompatible": "quarantine-without-application",
    "silentDrop": false,
    "silentMigration": false
  },
  "persistence": {
    "preview": "immediate",
    "debounceMs": 180,
    "atomic": true,
    "latestWriteWinsWithinTransaction": true,
    "crossProcessCoordination": "single-adapter-file-lock",
    "saveButton": false,
    "failure": "restore-last-valid-ui-renderer-disk-state"
  }
}
