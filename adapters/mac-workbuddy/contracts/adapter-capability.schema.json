{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-theme.local/contracts/mac-workbuddy-adapter-capability.schema.json",
  "title": "Mac WorkBuddy CC Theme adapter capability",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind", "schemaVersion", "capabilityVersion", "adapterId", "adapterVersion",
    "adapterReleaseRevision", "platform", "architecture", "available",
    "runtimeApplyAvailable", "catalogs", "compatibility", "sharedCore",
    "targetProfile", "localRuntimeOverrides", "paletteStrategy", "transactionSeam", "migration"
  ],
  "properties": {
    "kind": { "const": "cc-theme.adapter-capability" },
    "schemaVersion": { "const": 1 },
    "capabilityVersion": { "type": "integer", "const": 1 },
    "adapterId": { "const": "mac-workbuddy" },
    "adapterVersion": { "const": "5.2.6" },
    "adapterReleaseRevision": { "type": "integer", "const": 1 },
    "platform": { "const": "macos" },
    "architecture": { "const": "arm64" },
    "available": { "const": true },
    "runtimeApplyAvailable": { "const": true },
    "catalogs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skinThemeSchema", "themeStyleCatalog", "themeStyleCatalogVersion", "uiSurfaceCatalogPattern", "uiSurfaceCatalogSchemaVersion", "uiSurfaceCatalogVersion", "targetProfileSchema", "targetProfileSchemaVersion"],
      "properties": {
        "skinThemeSchema": { "$ref": "#/$defs/safeRelative" },
        "themeStyleCatalog": { "$ref": "#/$defs/safeRelative" },
        "themeStyleCatalogVersion": { "const": 2 },
        "uiSurfaceCatalogPattern": { "$ref": "#/$defs/safeRelative" },
        "uiSurfaceCatalogSchemaVersion": { "const": 2 },
        "uiSurfaceCatalogVersion": { "const": 2 },
        "targetProfileSchema": { "$ref": "#/$defs/safeRelative" },
        "targetProfileSchemaVersion": { "const": 1 }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy", "verifiedClientVersions", "runtimeProbeRequired", "applyDeniedCode"],
      "properties": {
        "policy": { "const": "verified-only" },
        "verifiedClientVersions": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^[A-Za-z0-9._+-]{1,80}$" } },
        "runtimeProbeRequired": { "const": true },
        "applyDeniedCode": { "const": "client-version-unsupported" }
      }
    },
    "sharedCore": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceKind", "fields"],
      "properties": {
        "sourceKind": { "const": "cc-theme.unified-theme" },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source", "decision", "required", "target", "diagnostic"],
            "properties": {
              "source": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9.*_-]{0,199}$" },
              "decision": { "enum": ["exact", "approximate", "unsupported"] },
              "required": { "type": "boolean" },
              "target": { "type": ["string", "null"], "maxLength": 160, "pattern": "^[A-Za-z][A-Za-z0-9.|_-]{0,159}$" },
              "diagnostic": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,79}$" },
              "condition": { "type": "string", "maxLength": 160 }
            }
          }
        }
      }
    },
    "targetProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "schema", "schemaVersion", "fields"],
      "properties": {
        "kind": { "const": "cc-theme.target-profile" },
        "schema": { "$ref": "#/$defs/safeRelative" },
        "schemaVersion": { "const": 1 },
        "fields": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false, "required": ["id", "decision"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]{0,79}$" },
              "decision": { "enum": ["exact", "approximate", "unsupported"] },
              "values": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
              "type": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]{0,39}$" }
            }
          }
        }
      }
    },
    "localRuntimeOverrides": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "schema", "schemaVersion", "catalog", "catalogVersion", "editableTokens", "rebase", "incompatible"],
      "properties": {
        "kind": { "const": "theme.runtime-settings" },
        "schema": { "$ref": "#/$defs/safeRelative" },
        "schemaVersion": { "const": 2 },
        "catalog": { "$ref": "#/$defs/safeRelative" },
        "catalogVersion": { "const": 1 },
        "editableTokens": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z][A-Za-z0-9.-]{0,79}$" } },
        "rebase": { "const": "validate-by-stable-token-and-control-fingerprint" },
        "incompatible": { "const": "quarantine-with-visible-diagnostic" }
      }
    },
    "paletteStrategy": {
      "type": "object", "additionalProperties": false,
      "required": ["precedence", "system", "adaptive", "custom", "adaptiveAuthoringAvailable", "adaptiveRuntimeAvailable"],
      "properties": {
        "precedence": { "const": ["shared-core", "target-profile", "local-runtime-override", "runtime-accessibility-and-host-safety"] },
        "system": { "type": "string", "minLength": 1, "maxLength": 320 },
        "adaptive": { "type": "string", "minLength": 1, "maxLength": 320 },
        "custom": { "type": "string", "minLength": 1, "maxLength": 320 },
        "adaptiveAuthoringAvailable": { "const": false },
        "adaptiveRuntimeAvailable": { "const": true }
      }
    },
    "transactionSeam": {
      "type": "object", "additionalProperties": false,
      "required": ["implementation", "scope", "serialization", "persistence", "writers"],
      "properties": {
        "implementation": { "$ref": "#/$defs/safeRelative" },
        "scope": { "const": "theme-id" },
        "serialization": { "const": "cross-process-exclusive-lock" },
        "persistence": { "const": "atomic-fsync-rename" },
        "writers": { "const": ["manager-apply", "workbuddy-settings"] }
      }
    },
    "migration": {
      "type": "object", "additionalProperties": false,
      "required": ["adapterIdPolicy", "localStateMigration", "legacyUnifiedTargetsCompatibility", "legacyOverridesWorkbuddy", "writePolicy", "removalEarliestCapabilityVersion"],
      "properties": {
        "adapterIdPolicy": { "const": "canonical-only-no-alias" },
        "localStateMigration": { "const": "one-time-pre-canonical-directory-move" },
        "legacyUnifiedTargetsCompatibility": { "type": "string", "minLength": 1, "maxLength": 160 },
        "legacyOverridesWorkbuddy": { "type": "string", "minLength": 1, "maxLength": 160 },
        "writePolicy": { "type": "string", "minLength": 1, "maxLength": 200 },
        "removalEarliestCapabilityVersion": { "type": "integer", "minimum": 2 }
      }
    }
  },
  "$defs": {
    "safeRelative": {
      "type": "string",
      "minLength": 3,
      "maxLength": 240,
      "pattern": "^(?!/)(?!.*\\.\\.)(?![A-Za-z]+:)(?!.*\\\\).+$"
    }
  }
}
