{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/quanzhankeji/cc-theme/main/adapters/mac-workbuddy/contracts/skin-theme.schema.json",
  "title": "WorkBuddy Skin Theme",
  "description": "Allowlisted local theme contract for the macOS WorkBuddy adapter.",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "id", "image"],
  "allOf": [
    { "not": { "required": ["backgroundVideo", "interactiveBackground"] } }
  ],
  "properties": {
    "kind": { "const": "skin.theme" },
    "id": { "type": "string", "pattern": "^[A-Za-z0-9_-]{1,80}$" },
    "name": { "type": "string", "minLength": 1, "maxLength": 80 },
    "image": { "$ref": "#/$defs/imageFile" },
    "backgroundVideo": { "$ref": "#/$defs/videoFile" },
    "interactiveBackground": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": { "const": "ripple" },
            "intensity": { "type": "number", "minimum": 0, "maximum": 1 },
            "radiusPx": { "type": "number", "minimum": 8, "maximum": 96 },
            "quality": { "enum": ["auto", "low", "high"] },
            "scrimOpacity": { "type": "number", "minimum": 0, "maximum": 0.8 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "atlas", "directions", "columns", "rows"],
          "properties": {
            "type": { "const": "directional" },
            "atlas": { "$ref": "#/$defs/staticWebpFile" },
            "directions": { "enum": [8, 16, 32] },
            "columns": { "type": "integer", "minimum": 1, "maximum": 8 },
            "rows": { "type": "integer", "minimum": 1, "maximum": 8 },
            "firstDirectionDegrees": { "type": "number", "minimum": -180, "maximum": 180 },
            "idleFrame": { "type": "integer", "minimum": 0, "maximum": 31 },
            "origin": { "$ref": "#/$defs/position" },
            "scrimOpacity": { "type": "number", "minimum": 0, "maximum": 0.8 }
          }
        }
      ]
    },
    "presentation": { "$ref": "#/$defs/immersiveScenePresentation" },
    "colors": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "background": { "$ref": "#/$defs/color" },
        "panel": { "$ref": "#/$defs/color" },
        "panelAlt": { "$ref": "#/$defs/color" },
        "accent": { "$ref": "#/$defs/color" },
        "accentAlt": { "$ref": "#/$defs/color" },
        "secondary": { "$ref": "#/$defs/color" },
        "highlight": { "$ref": "#/$defs/color" },
        "text": { "$ref": "#/$defs/color" },
        "muted": { "$ref": "#/$defs/color" },
        "line": { "$ref": "#/$defs/color" }
      }
    },
    "semanticColors": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "surfaceBase": { "$ref": "#/$defs/color" },
        "surfaceRaised": { "$ref": "#/$defs/color" },
        "surfaceElevated": { "$ref": "#/$defs/color" },
        "surfaceMuted": { "$ref": "#/$defs/color" },
        "textStrong": { "$ref": "#/$defs/color" },
        "textSecondary": { "$ref": "#/$defs/color" },
        "textDisabled": { "$ref": "#/$defs/color" },
        "iconPrimary": { "$ref": "#/$defs/color" },
        "iconMuted": { "$ref": "#/$defs/color" },
        "placeholder": { "$ref": "#/$defs/color" },
        "borderSubtle": { "$ref": "#/$defs/color" },
        "borderDefault": { "$ref": "#/$defs/color" },
        "divider": { "$ref": "#/$defs/color" },
        "action": { "$ref": "#/$defs/color" },
        "actionHover": { "$ref": "#/$defs/color" },
        "actionPressed": { "$ref": "#/$defs/color" },
        "actionForeground": { "$ref": "#/$defs/color" },
        "hoverSurface": { "$ref": "#/$defs/color" },
        "pressedSurface": { "$ref": "#/$defs/color" },
        "selectedSurface": { "$ref": "#/$defs/color" },
        "focusRing": { "$ref": "#/$defs/color" },
        "link": { "$ref": "#/$defs/color" },
        "sidebarSurface": { "$ref": "#/$defs/color" },
        "headerSurface": { "$ref": "#/$defs/color" },
        "mainScrimStart": { "$ref": "#/$defs/color" },
        "mainScrimMid": { "$ref": "#/$defs/color" },
        "mainScrimEnd": { "$ref": "#/$defs/color" },
        "composerSurface": { "$ref": "#/$defs/color" },
        "overlayScrim": { "$ref": "#/$defs/color" },
        "detailScrim": { "$ref": "#/$defs/color" },
        "shadowColor": { "$ref": "#/$defs/color" },
        "danger": { "$ref": "#/$defs/color" },
        "controlTrack": { "$ref": "#/$defs/color" },
        "controlTrackActive": { "$ref": "#/$defs/color" },
        "controlThumb": { "$ref": "#/$defs/color" }
      }
    },
    "fonts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ui": { "$ref": "#/$defs/fontList" },
        "display": { "$ref": "#/$defs/fontList" },
        "code": { "$ref": "#/$defs/fontList" }
      }
    },
    "appearance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "paletteStrategy": { "enum": ["system", "adaptive", "custom"] },
        "shellMode": { "const": "auto" },
        "backgroundVideoPosterMode": { "enum": ["none", "image"] },
        "backgroundPosition": { "$ref": "#/$defs/position" },
        "backgroundScrimOpacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "backdropBlurPx": { "type": "number", "minimum": 0, "maximum": 48 },
        "backdropSaturation": { "type": "number", "minimum": 0.5, "maximum": 1.5 },
        "radiusScale": { "type": "number", "minimum": 0.75, "maximum": 1.5 }
      }
    }
  },
  "$defs": {
    "color": {
      "type": "string",
      "pattern": "^(#[0-9A-Fa-f]{6}|rgba?\\([0-9., %]+\\))$"
    },
    "imageFile": {
      "type": "string",
      "pattern": "^[^/\\\\]+\\.(png|jpe?g|webp)$"
    },
    "videoFile": {
      "type": "string",
      "pattern": "^[^/\\\\]+\\.mp4$"
    },
    "staticWebpFile": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+\\.webp$"
    },
    "fontList": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": { "type": "string", "minLength": 1, "maxLength": 80 }
    },
    "immersiveScenePresentation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profileId", "profileVersion", "strictness", "geometryPolicy", "surfaces", "parameters", "assetSlots", "fallbackPolicy"],
      "properties": {
        "profileId": { "const": "immersive-scene-v1" },
        "profileVersion": { "const": 1 },
        "strictness": { "const": "exact-required" },
        "geometryPolicy": { "const": "scene-bounded" },
        "surfaces": { "type": "array", "uniqueItems": true, "minItems": 7, "maxItems": 7, "items": { "enum": ["shell", "navigation", "home", "conversation", "composer", "cards", "overlays"] } },
        "parameters": {
          "type": "object", "additionalProperties": false,
          "required": ["density", "borderTreatment", "textureIntensity", "surfaceOpacity", "navigationTreatment", "composerTreatment", "cardTreatment"],
          "properties": {
            "density": { "const": "comfortable" }, "borderTreatment": { "const": "etched" },
            "textureIntensity": { "type": "number", "minimum": 0, "maximum": 1 },
            "surfaceOpacity": { "type": "number", "minimum": 0, "maximum": 1 },
            "navigationTreatment": { "const": "framed" }, "composerTreatment": { "const": "anchored" }, "cardTreatment": { "const": "elevated" }
          }
        },
        "assetSlots": { "type": "object", "additionalProperties": false, "required": ["scene.backdrop"], "properties": { "scene.backdrop": { "$ref": "#/$defs/imageFile" } } },
        "fallbackPolicy": { "type": "object", "additionalProperties": false, "required": ["unsupportedSurface", "reducedMotion"], "properties": { "unsupportedSurface": { "const": "block" }, "reducedMotion": { "const": "static" } } }
      }
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["xPercent", "yPercent"],
      "properties": {
        "xPercent": { "type": "number", "minimum": 0, "maximum": 100 },
        "yPercent": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    }
  }
}
