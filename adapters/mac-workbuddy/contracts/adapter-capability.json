{
  "kind": "cc-theme.adapter-capability",
  "schemaVersion": 1,
  "capabilityVersion": 1,
  "adapterId": "mac-workbuddy",
  "adapterVersion": "5.2.6",
  "adapterReleaseRevision": 2,
  "platform": "macos",
  "architecture": "arm64",
  "available": true,
  "runtimeApplyAvailable": true,
  "catalogs": {
    "skinThemeSchema": "contracts/skin-theme.schema.json",
    "themeStyleCatalog": "contracts/theme-style-catalog.json",
    "themeStyleCatalogVersion": 2,
    "uiSurfaceCatalogPattern": "compatibility/workbuddy-macos/<client-version>/ui-surface-catalog.json",
    "uiSurfaceCatalogSchemaVersion": 2,
    "uiSurfaceCatalogVersion": 2,
    "targetProfileSchema": "contracts/target-profile.schema.json",
    "targetProfileSchemaVersion": 1
  },
  "compatibility": {
    "policy": "verified-only",
    "verifiedClientVersions": ["5.2.6"],
    "runtimeProbeRequired": true,
    "applyDeniedCode": "client-version-unsupported"
  },
  "sharedCore": {
    "sourceKind": "cc-theme.unified-theme",
    "fields": [
      { "source": "id", "decision": "exact", "required": true, "target": "id", "diagnostic": "mapped-exact" },
      { "source": "name", "decision": "exact", "required": true, "target": "name", "diagnostic": "mapped-exact" },
      { "source": "version", "decision": "exact", "required": true, "target": "sourceVersion", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.surfaceBase", "decision": "exact", "required": true, "target": "semanticColors.surfaceBase", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.surfaceRaised", "decision": "exact", "required": false, "target": "semanticColors.surfaceRaised", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.surfaceElevated", "decision": "exact", "required": false, "target": "semanticColors.surfaceElevated", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.surfaceCode", "decision": "approximate", "required": false, "target": "semanticColors.surfaceRaised", "diagnostic": "approximated-surface-code", "condition": "used only when surfaceRaised is absent" },
      { "source": "tokens.colors.text", "decision": "exact", "required": true, "target": "colors.text", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.textStrong", "decision": "exact", "required": false, "target": "semanticColors.textStrong", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.textMuted", "decision": "exact", "required": true, "target": "colors.muted", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.placeholder", "decision": "exact", "required": false, "target": "semanticColors.placeholder", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.borderSubtle", "decision": "exact", "required": false, "target": "semanticColors.borderSubtle", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.borderDefault", "decision": "exact", "required": false, "target": "semanticColors.borderDefault", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.borderStrong", "decision": "approximate", "required": false, "target": "semanticColors.borderDefault", "diagnostic": "approximated-border-strong", "condition": "used only when borderDefault is absent" },
      { "source": "tokens.colors.action", "decision": "exact", "required": true, "target": "semanticColors.action", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.actionHover", "decision": "exact", "required": false, "target": "semanticColors.actionHover", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.actionPressed", "decision": "exact", "required": false, "target": "semanticColors.actionPressed", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.actionForeground", "decision": "exact", "required": true, "target": "semanticColors.actionForeground", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.hoverSurface", "decision": "exact", "required": false, "target": "semanticColors.hoverSurface", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.pressedSurface", "decision": "exact", "required": false, "target": "semanticColors.pressedSurface", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.selectedSurface", "decision": "exact", "required": false, "target": "semanticColors.selectedSurface", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.selectedHoverSurface", "decision": "approximate", "required": false, "target": "semanticColors.selectedSurface", "diagnostic": "approximated-selected-hover", "condition": "used only when selectedSurface is absent" },
      { "source": "tokens.colors.focusRing", "decision": "exact", "required": true, "target": "semanticColors.focusRing", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.link", "decision": "exact", "required": false, "target": "semanticColors.link", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.danger", "decision": "exact", "required": false, "target": "semanticColors.danger", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.success", "decision": "unsupported", "required": false, "target": null, "diagnostic": "optional-field-unsupported" },
      { "source": "tokens.colors.warning", "decision": "unsupported", "required": false, "target": null, "diagnostic": "optional-field-unsupported" },
      { "source": "tokens.colors.sidebarSurface", "decision": "exact", "required": false, "target": "semanticColors.sidebarSurface", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.headerSurface", "decision": "exact", "required": false, "target": "semanticColors.headerSurface", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.mainScrimStart", "decision": "exact", "required": false, "target": "semanticColors.mainScrimStart", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.mainScrimMid", "decision": "exact", "required": false, "target": "semanticColors.mainScrimMid", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.mainScrimEnd", "decision": "exact", "required": false, "target": "semanticColors.mainScrimEnd", "diagnostic": "mapped-exact" },
      { "source": "tokens.colors.composerSurface", "decision": "exact", "required": false, "target": "semanticColors.composerSurface", "diagnostic": "mapped-exact" },
      { "source": "tokens.fonts.ui", "decision": "exact", "required": false, "target": "fonts.ui", "diagnostic": "mapped-exact" },
      { "source": "tokens.fonts.display", "decision": "exact", "required": false, "target": "fonts.display", "diagnostic": "mapped-exact" },
      { "source": "tokens.fonts.code", "decision": "exact", "required": false, "target": "fonts.code", "diagnostic": "mapped-exact" },
      { "source": "tokens.appearance.shellMode", "decision": "unsupported", "required": false, "target": null, "diagnostic": "host-shell-mode-authority", "condition": "WorkBuddy effective light/dark appearance remains the sole runtime authority" },
      { "source": "tokens.appearance.backdropBlurPx", "decision": "exact", "required": false, "target": "appearance.backdropBlurPx", "diagnostic": "mapped-exact" },
      { "source": "tokens.appearance.backdropSaturation", "decision": "exact", "required": false, "target": "appearance.backdropSaturation", "diagnostic": "mapped-exact" },
      { "source": "tokens.appearance.radiusScale", "decision": "exact", "required": false, "target": "appearance.radiusScale", "diagnostic": "mapped-exact" },
      { "source": "tokens.appearance.backgroundPosition", "decision": "approximate", "required": false, "target": "appearance.backgroundPosition", "diagnostic": "legacy-background-position-fallback", "condition": "legacy compatibility input; used only when background.position is absent; conflicts fail closed" },
      { "source": "tokens.appearance.homeHeroPosition", "decision": "unsupported", "required": false, "target": null, "diagnostic": "home-hero-unsupported" },
      { "source": "background.image", "decision": "exact", "required": true, "target": "image", "diagnostic": "mapped-exact" },
      { "source": "background.video", "decision": "exact", "required": false, "target": "backgroundVideo", "diagnostic": "mapped-exact" },
      { "source": "background.posterMode", "decision": "exact", "required": false, "target": "appearance.backgroundVideoPosterMode", "diagnostic": "mapped-exact" },
      { "source": "background.position", "decision": "exact", "required": false, "target": "appearance.backgroundPosition", "diagnostic": "mapped-exact" },
      { "source": "background.homeHeroImage", "decision": "unsupported", "required": false, "target": null, "diagnostic": "home-hero-unsupported" },
      { "source": "background.scrimOpacity", "decision": "exact", "required": false, "target": "appearance.backgroundScrimOpacity|interactiveBackground.scrimOpacity", "diagnostic": "mapped-exact" },
      { "source": "background.mode.media", "decision": "exact", "required": false, "target": "backgroundRenderMode.media", "diagnostic": "mapped-exact" },
      { "source": "background.mode.ripple", "decision": "exact", "required": false, "target": "interactiveBackground", "diagnostic": "mapped-exact" },
      { "source": "background.ripple.intensity", "decision": "exact", "required": false, "target": "interactiveBackground.intensity", "diagnostic": "mapped-exact" },
      { "source": "background.ripple.radiusPx", "decision": "exact", "required": false, "target": "interactiveBackground.radiusPx", "diagnostic": "mapped-exact" },
      { "source": "background.ripple.quality", "decision": "exact", "required": false, "target": "interactiveBackground.quality", "diagnostic": "mapped-exact" },
      { "source": "background.mode.directional", "decision": "exact", "required": false, "target": "interactiveBackground", "diagnostic": "mapped-exact" },
      { "source": "background.directional.atlas", "decision": "exact", "required": false, "target": "interactiveBackground.atlas", "diagnostic": "mapped-exact" },
      { "source": "background.directional.directions", "decision": "exact", "required": false, "target": "interactiveBackground.directions", "diagnostic": "mapped-exact" },
      { "source": "background.directional.columns", "decision": "exact", "required": false, "target": "interactiveBackground.columns", "diagnostic": "mapped-exact" },
      { "source": "background.directional.rows", "decision": "exact", "required": false, "target": "interactiveBackground.rows", "diagnostic": "mapped-exact" },
      { "source": "background.directional.firstDirectionDegrees", "decision": "exact", "required": false, "target": "interactiveBackground.firstDirectionDegrees", "diagnostic": "mapped-exact" },
      { "source": "background.directional.idleFrame", "decision": "exact", "required": false, "target": "interactiveBackground.idleFrame", "diagnostic": "mapped-exact" },
      { "source": "background.directional.origin", "decision": "exact", "required": false, "target": "interactiveBackground.origin", "diagnostic": "mapped-exact" },
      { "source": "accessibility.reducedMotion", "decision": "exact", "required": true, "target": "runtime.forceStatic", "diagnostic": "runtime-safety-applied" },
      { "source": "accessibility.minimumTextContrast", "decision": "unsupported", "required": false, "target": null, "diagnostic": "contrast-audit-unavailable" },
      { "source": "accessibility.minimumLargeTextContrast", "decision": "unsupported", "required": false, "target": null, "diagnostic": "contrast-audit-unavailable" },
      { "source": "accessibility.preserveSystemFocusRing", "decision": "approximate", "required": false, "target": "semanticColors.focusRing|hostFocus", "diagnostic": "focus-ring-strategy-approximate", "condition": "native in system; semantic focusRing in adaptive/custom" },
      { "source": "accessibility.transparencyFallback", "decision": "unsupported", "required": false, "target": null, "diagnostic": "transparency-preference-unavailable" },
      { "source": "copy.*", "decision": "unsupported", "required": false, "target": null, "diagnostic": "copy-surface-unsupported" }
    ]
  },
  "targetProfile": {
    "kind": "cc-theme.target-profile",
    "schema": "contracts/target-profile.schema.json",
    "schemaVersion": 1,
    "fields": [
      { "id": "paletteStrategy", "decision": "exact", "values": ["system", "adaptive", "custom"] },
      { "id": "backgroundVideoPosterMode", "decision": "exact", "values": ["none", "image"] }
    ]
  },
  "presentationProfiles": {
    "immersive-scene-v1": {
      "profileVersion": 1,
      "geometryPolicy": "scene-bounded",
      "surfaces": {
        "shell": "exact",
        "navigation": "exact",
        "home": "exact",
        "conversation": "exact",
        "composer": "exact",
        "cards": "exact",
        "overlays": "exact"
      }
    }
  },
  "localRuntimeOverrides": {
    "kind": "theme.runtime-settings",
    "schema": "contracts/theme-runtime-settings.schema.json",
    "schemaVersion": 2,
    "catalog": "contracts/theme-style-catalog.json",
    "catalogVersion": 2,
    "editableTokens": [
      "palette.strategy", "background.presentation",
      "foundation.surfaceBase", "foundation.surfaceRaised", "foundation.surfaceElevated",
      "text.primary", "text.secondary", "interaction.accent", "border.default",
      "typography.ui", "typography.display", "typography.code", "media.interactiveScrim",
      "media.backgroundScrimOpacity", "media.backgroundPosition",
      "media.blur", "media.saturation"
    ],
    "rebase": "validate-by-stable-token-and-control-fingerprint",
    "incompatible": "quarantine-with-visible-diagnostic"
  },
  "paletteStrategy": {
    "precedence": ["shared-core", "target-profile", "local-runtime-override", "runtime-accessibility-and-host-safety"],
    "system": "WorkBuddy native system colors are the active base; supported Shared Core colors remain validated dormant intent and local overrides remain preserved.",
    "adaptive": "Shared Core colors form the adaptive base; Target Profile selects adaptive and Local Runtime Overrides apply last.",
    "custom": "Shared Core colors are initial values; Target Profile selects custom and allowlisted Local Runtime Override colors apply last.",
    "adaptiveAuthoringAvailable": false,
    "adaptiveRuntimeAvailable": true
  },
  "transactionSeam": {
    "implementation": "scripts/adapter-transaction.mjs",
    "scope": "theme-id",
    "serialization": "cross-process-exclusive-lock",
    "persistence": "atomic-fsync-rename",
    "writers": ["manager-apply", "workbuddy-settings"]
  },
  "migration": {
    "adapterIdPolicy": "canonical-only-no-alias",
    "localStateMigration": "one-time-pre-canonical-directory-move",
    "legacyUnifiedTargetsCompatibility": "read-only-through-unified-schema-v1",
    "legacyOverridesWorkbuddy": "read-with-visible-deprecation-diagnostic",
    "writePolicy": "all outputs and persisted writes use the canonical adapter id and namespaced Target Profile",
    "removalEarliestCapabilityVersion": 2
  }
}
