    { "id": "host.cbTextTertiary", "group": "hostBridge", "cssVariable": "--cb-text-tertiary", "source": "host.cbTextTertiary", "roles": ["main-content"] },
    { "id": "host.cbPanelBorder", "group": "hostBridge", "cssVariable": "--cb-panel-border-color", "source": "host.cbPanelBorder", "roles": ["main-content"] },
    { "id": "host.cbMainBackground", "group": "hostBridge", "cssVariable": "--cb-main-area-background", "source": "host.cbMainBackground", "roles": ["composer"] },
    { "id": "host.cbMainBorder", "group": "hostBridge", "cssVariable": "--cb-main-area-border-color", "source": "host.cbMainBorder", "roles": ["composer"] },
    { "id": "host.cbMainShadow", "group": "hostBridge", "cssVariable": "--cb-main-area-box-shadow", "source": "host.cbMainShadow", "roles": ["composer"] },
    { "id": "host.cbPopoverBackground", "group": "hostBridge", "cssVariable": "--cb-popover-background", "source": "host.cbPopoverBackground", "roles": ["overlay-popover"] },
    { "id": "host.cbPopoverBorder", "group": "hostBridge", "cssVariable": "--cb-popover-border", "source": "host.cbPopoverBorder", "roles": ["overlay-popover"] },
    { "id": "host.cbPopoverShadow", "group": "hostBridge", "cssVariable": "--cb-shadow-popover", "source": "host.cbPopoverShadow", "roles": ["overlay-popover"] }
