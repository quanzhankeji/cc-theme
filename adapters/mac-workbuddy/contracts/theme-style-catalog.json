    { "id": "foundation.panel", "group": "foundation", "cssVariable": "--wbs-panel", "source": "palette.panel", "roles": ["main-content"] },
    { "id": "foundation.panelAlt", "group": "foundation", "cssVariable": "--wbs-panel-alt", "source": "palette.panelAlt", "roles": ["main-content"] },
