    { "id": "foundation.surfaceBase", "group": "foundation", "cssVariable": "--wbs-surface-base", "source": "palette.surface", "roles": ["main-content", "settings-content"] },
    { "id": "foundation.surfaceRaised", "group": "foundation", "cssVariable": "--wbs-surface-raised", "source": "palette.surfaceRaised", "roles": ["artifact-card", "settings-content"] },
    { "id": "foundation.surfaceElevated", "group": "foundation", "cssVariable": "--wbs-surface-elevated", "source": "palette.surfaceElevated", "roles": ["overlay-popover", "overlay-settings-modal"] },
    { "id": "foundation.surfaceMuted", "group": "foundation", "cssVariable": "--wbs-surface-muted", "source": "palette.surfaceMuted", "roles": ["sidebar-nav-row"] },
    { "id": "text.primary", "group": "text", "cssVariable": "--wbs-text", "source": "palette.text", "roles": ["main-content", "sidebar"] },
    { "id": "text.strong", "group": "text", "cssVariable": "--wbs-text-strong", "source": "palette.textStrong", "roles": ["home-heading", "settings-content"] },
    { "id": "text.secondary", "group": "text", "cssVariable": "--wbs-text-secondary", "source": "palette.textSecondary", "roles": ["main-content", "settings-content"] },
    { "id": "text.muted", "group": "text", "cssVariable": "--wbs-muted", "source": "palette.textMuted", "roles": ["main-content"] },
    { "id": "text.disabled", "group": "text", "cssVariable": "--wbs-text-disabled", "source": "palette.textDisabled", "roles": ["settings-content"] },
    { "id": "text.placeholder", "group": "text", "cssVariable": "--wbs-placeholder", "source": "palette.placeholder", "roles": ["composer-input"] },
    { "id": "text.icon", "group": "text", "cssVariable": "--wbs-icon", "source": "palette.icon", "roles": ["sidebar", "main-content"] },
    { "id": "text.iconMuted", "group": "text", "cssVariable": "--wbs-icon-muted", "source": "palette.iconMuted", "roles": ["sidebar"] },
    { "id": "text.link", "group": "text", "cssVariable": "--wbs-link", "source": "palette.link", "roles": ["main-content"] },
    { "id": "navigation.sidebar", "group": "navigation", "cssVariable": "--wbs-sidebar", "source": "palette.sidebar", "roles": ["sidebar"] },
    { "id": "navigation.header", "group": "navigation", "cssVariable": "--wbs-header", "source": "palette.header", "roles": ["topbar"] },
    { "id": "content.composer", "group": "content", "cssVariable": "--wbs-composer", "source": "palette.composer", "roles": ["composer"] },
    { "id": "content.scrimStart", "group": "content", "cssVariable": "--wbs-main-scrim-start", "source": "palette.mainScrimStart", "roles": ["main"] },
    { "id": "content.scrimMiddle", "group": "content", "cssVariable": "--wbs-main-scrim-mid", "source": "palette.mainScrimMid", "roles": ["main"] },
    { "id": "content.scrimEnd", "group": "content", "cssVariable": "--wbs-main-scrim-end", "source": "palette.mainScrimEnd", "roles": ["main"] },
    { "id": "content.overlayScrim", "group": "content", "cssVariable": "--wbs-overlay-scrim", "source": "palette.overlayScrim", "roles": ["overlay-scrim"] },
    { "id": "content.detailScrim", "group": "content", "cssVariable": "--wbs-detail-scrim", "source": "palette.detailScrim", "roles": ["overlay-detail-scrim"] },
    { "id": "interaction.accent", "group": "interaction", "cssVariable": "--wbs-accent", "source": "palette.accent", "roles": ["main-content"] },
    { "id": "interaction.accentAlt", "group": "interaction", "cssVariable": "--wbs-accent-alt", "source": "palette.accentAlt", "roles": ["main-content"] },
    { "id": "interaction.secondary", "group": "interaction", "cssVariable": "--wbs-secondary", "source": "palette.secondary", "roles": ["main-content"] },
    { "id": "interaction.highlight", "group": "interaction", "cssVariable": "--wbs-highlight", "source": "palette.highlight", "roles": ["main-content"] },
    { "id": "interaction.action", "group": "interaction", "cssVariable": "--wbs-action", "source": "palette.action", "roles": ["composer", "settings-content"] },
    { "id": "interaction.actionHover", "group": "interaction", "cssVariable": "--wbs-action-hover", "source": "palette.actionHover", "roles": ["composer", "settings-content"] },
    { "id": "interaction.actionPressed", "group": "interaction", "cssVariable": "--wbs-action-pressed", "source": "palette.actionPressed", "roles": ["scene-tab", "account-plan-action"] },
    { "id": "interaction.actionForeground", "group": "interaction", "cssVariable": "--wbs-action-foreground", "source": "palette.actionForeground", "roles": ["composer", "settings-content"] },
    { "id": "interaction.hover", "group": "interaction", "cssVariable": "--wbs-hover", "source": "palette.hover", "roles": ["sidebar-nav-row", "settings-navigation-item"] },
    { "id": "interaction.pressed", "group": "interaction", "cssVariable": "--wbs-pressed", "source": "palette.pressed", "roles": ["sidebar-nav-row", "settings-navigation-item"] },
    { "id": "interaction.selected", "group": "interaction", "cssVariable": "--wbs-selected", "source": "palette.selected", "roles": ["sidebar-nav-row", "settings-navigation-item"] },
    { "id": "interaction.danger", "group": "interaction", "cssVariable": "--wbs-danger", "source": "palette.danger", "roles": ["settings-content"] },
    { "id": "interaction.controlTrack", "group": "interaction", "cssVariable": "--wbs-control-track", "source": "palette.controlTrack", "roles": ["settings-content"] },
    { "id": "interaction.controlTrackActive", "group": "interaction", "cssVariable": "--wbs-control-track-active", "source": "palette.controlTrackActive", "roles": ["settings-content"] },
    { "id": "interaction.controlThumb", "group": "interaction", "cssVariable": "--wbs-control-thumb", "source": "palette.controlThumb", "roles": ["settings-content"] },
    { "id": "border.line", "group": "border", "cssVariable": "--wbs-line", "source": "palette.line", "roles": ["shell"] },
    { "id": "border.subtle", "group": "border", "cssVariable": "--wbs-border-subtle", "source": "palette.borderSubtle", "roles": ["main-content", "settings-content"] },
    { "id": "border.default", "group": "border", "cssVariable": "--wbs-border", "source": "palette.border", "roles": ["main-content", "settings-content"] },
    { "id": "border.divider", "group": "border", "cssVariable": "--wbs-divider", "source": "palette.divider", "roles": ["settings-content"] },
    { "id": "border.focus", "group": "border", "cssVariable": "--wbs-focus", "source": "palette.focus", "roles": ["composer", "settings-content"] },
    { "id": "typography.ui", "group": "typography", "cssVariable": "--wbs-font-ui", "source": "layout.fontUi", "roles": ["shell"] },
    { "id": "typography.display", "group": "typography", "cssVariable": "--wbs-font-display", "source": "layout.fontDisplay", "roles": ["home-heading"] },
    { "id": "typography.code", "group": "typography", "cssVariable": "--wbs-font-code", "source": "layout.fontCode", "roles": ["main-content"] },
    { "id": "media.backgroundX", "group": "media", "cssVariable": "--wbs-background-x", "source": "layout.backgroundX", "roles": ["shell"] },
    { "id": "media.backgroundY", "group": "media", "cssVariable": "--wbs-background-y", "source": "layout.backgroundY", "roles": ["shell"] },
    { "id": "media.blur", "group": "media", "cssVariable": "--wbs-blur", "source": "layout.blur", "roles": ["shell"] },
    { "id": "media.saturation", "group": "media", "cssVariable": "--wbs-saturation", "source": "layout.saturation", "roles": ["shell"] },
    { "id": "media.radiusScale", "group": "media", "cssVariable": "--wbs-radius-scale", "source": "layout.radiusScale", "roles": ["shell"] },
    { "id": "media.interactiveScrim", "group": "media", "cssVariable": "--wbs-interactive-scrim-opacity", "source": "layout.interactiveScrim", "roles": ["shell"] },
    { "id": "media.backgroundScrimOpacity", "group": "media", "cssVariable": "--wbs-background-scrim-opacity", "source": "layout.backgroundScrimOpacity", "roles": ["shell"] },
    { "id": "media.videoControlSize", "group": "media", "cssVariable": "--wbs-video-toggle-size", "source": "layout.videoControlSize", "roles": ["video-playback-control"] },
    { "id": "elevation.shadowColor", "group": "elevation", "cssVariable": "--wbs-shadow-color", "source": "palette.shadowColor", "roles": ["shell"] },
    { "id": "elevation.sidebar", "group": "elevation", "cssVariable": "--wbs-shadow-sidebar", "value": "12px 0 32px color-mix(in srgb, var(--wbs-shadow-color) 14%, transparent)", "roles": ["sidebar"] },
    { "id": "elevation.input", "group": "elevation", "cssVariable": "--wbs-shadow-input", "value": "0 18px 54px color-mix(in srgb, var(--wbs-shadow-color) 26%, transparent)", "roles": ["composer"] },
    { "id": "elevation.inputFocus", "group": "elevation", "cssVariable": "--wbs-shadow-input-focus", "value": "0 0 0 1px var(--wbs-focus), 0 20px 60px color-mix(in srgb, var(--wbs-shadow-color) 30%, transparent)", "roles": ["composer"] },
    { "id": "elevation.popover", "group": "elevation", "cssVariable": "--wbs-shadow-popover", "value": "0 8px 24px -6px color-mix(in srgb, var(--wbs-shadow-color) 24%, transparent), 0 3px 8px -4px color-mix(in srgb, var(--wbs-shadow-color) 16%, transparent)", "roles": ["overlay-popover"] },
    { "id": "elevation.modal", "group": "elevation", "cssVariable": "--wbs-shadow-modal", "value": "0 18px 48px -8px color-mix(in srgb, var(--wbs-shadow-color) 34%, transparent)", "roles": ["overlay-settings-modal"] },
    { "id": "elevation.detail", "group": "elevation", "cssVariable": "--wbs-shadow-detail", "value": "0 24px 80px color-mix(in srgb, var(--wbs-shadow-color) 38%, transparent)", "roles": ["overlay-detail-modal"] },
    { "id": "elevation.title", "group": "elevation", "cssVariable": "--wbs-shadow-title", "value": "0 2px 24px color-mix(in srgb, var(--wbs-shadow-color) 28%, transparent)", "roles": ["home-heading"] },
    { "id": "border.table", "group": "border", "cssVariable": "--wbs-table-border", "value": "color-mix(in srgb, var(--wbs-text) 10%, transparent)", "roles": ["markdown-table"] },
    { "id": "interaction.motionFast", "group": "interaction", "cssVariable": "--wbs-motion-fast", "value": "140ms", "roles": ["shell"] },
    { "id": "host.homePrimary", "group": "hostBridge", "cssVariable": "--wb-home-bg-primary", "source": "host.homePrimary", "roles": ["page-home"] },
    { "id": "host.homeSecondary", "group": "hostBridge", "cssVariable": "--wb-home-bg-secondary", "source": "host.homeSecondary", "roles": ["page-home"] },
    { "id": "host.sidebarBackground", "group": "hostBridge", "cssVariable": "--wb-sidebar-bg", "source": "host.sidebarBackground", "roles": ["sidebar"] },
    { "id": "host.backgroundPrimary", "group": "hostBridge", "cssVariable": "--wb-bg-primary", "source": "host.backgroundPrimary", "roles": ["main-content"] },
    { "id": "host.backgroundSecondary", "group": "hostBridge", "cssVariable": "--wb-bg-secondary", "source": "host.backgroundSecondary", "roles": ["main-content"] },
    { "id": "host.backgroundTertiary", "group": "hostBridge", "cssVariable": "--wb-bg-tertiary", "source": "host.backgroundTertiary", "roles": ["main-content"] },
    { "id": "host.backgroundHover", "group": "hostBridge", "cssVariable": "--wb-bg-hover", "source": "host.backgroundHover", "roles": ["main-content"] },
    { "id": "host.backgroundActive", "group": "hostBridge", "cssVariable": "--wb-bg-active", "source": "host.backgroundActive", "roles": ["main-content"] },
    { "id": "host.textPrimary", "group": "hostBridge", "cssVariable": "--wb-color-text-primary", "source": "host.textPrimary", "roles": ["main-content"] },
    { "id": "host.textSecondary", "group": "hostBridge", "cssVariable": "--wb-color-text-secondary", "source": "host.textSecondary", "roles": ["main-content"] },
    { "id": "host.textTertiary", "group": "hostBridge", "cssVariable": "--wb-color-text-tertiary", "source": "host.textTertiary", "roles": ["main-content"] },
    { "id": "host.borderDefault", "group": "hostBridge", "cssVariable": "--wb-border-default", "source": "host.borderDefault", "roles": ["main-content"] },
    { "id": "host.borderWeak", "group": "hostBridge", "cssVariable": "--wb-border-weak", "source": "host.borderWeak", "roles": ["main-content"] },
    { "id": "host.borderStrong", "group": "hostBridge", "cssVariable": "--wb-border-strong", "source": "host.borderStrong", "roles": ["main-content"] },
    { "id": "host.shadowPopover", "group": "hostBridge", "cssVariable": "--wb-shadow-popover", "source": "host.shadowPopover", "roles": ["overlay-popover"] },
    { "id": "host.shadowInput", "group": "hostBridge", "cssVariable": "--wb-shadow-input", "source": "host.shadowInput", "roles": ["composer"] },
