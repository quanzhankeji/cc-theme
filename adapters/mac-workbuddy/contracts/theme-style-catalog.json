{
  "kind": "theme.style-catalog",
  "schemaVersion": 1,
  "catalogVersion": 2,
  "adapterId": "mac-workbuddy",
  "adapterVersion": "5.2.6",
  "adapterReleaseRevision": 2,
  "catalogId": "mac-workbuddy-theme",
  "geometryPolicy": "native",
  "description": "Paint-only bindings consumed by the fixed WorkBuddy UI interpreter. DOM geometry remains host-owned.",
  "groups": [
    { "id": "foundation" },
    { "id": "text" },
    { "id": "navigation" },
    { "id": "content" },
    { "id": "interaction" },
    { "id": "border" },
    { "id": "typography" },
    { "id": "media" },
    { "id": "elevation" },
    { "id": "hostBridge" }
  ],
  "settingsControls": [
    { "id": "theme.selection", "group": "theme", "type": "theme", "source": "theme.id", "labelKey": "controlTheme" },
    { "id": "palette.strategy", "group": "palette", "type": "select", "source": "theme.paletteStrategy", "labelKey": "controlPalette", "options": ["system", "adaptive", "custom"], "immediate": true },
    { "id": "background.presentation", "group": "background", "type": "backgroundState", "source": "runtime.backgroundPresentation", "labelKey": "backgroundEffect", "options": ["enabled", "paused", "disabled"], "immediate": true },
    { "id": "foundation.surfaceBase", "group": "color", "type": "color", "source": "style.foundation.surfaceBase", "binding": "foundation.surfaceBase", "labelKey": "controlSurfaceBase", "paletteStrategies": ["adaptive", "custom"] },
    { "id": "foundation.surfaceRaised", "group": "color", "type": "color", "source": "style.foundation.surfaceRaised", "binding": "foundation.surfaceRaised", "labelKey": "controlSurfaceRaised", "paletteStrategies": ["adaptive", "custom"] },
    { "id": "foundation.surfaceElevated", "group": "color", "type": "color", "source": "style.foundation.surfaceElevated", "binding": "foundation.surfaceElevated", "labelKey": "controlSurfaceElevated", "paletteStrategies": ["adaptive", "custom"] },
    { "id": "text.primary", "group": "color", "type": "color", "source": "style.text.primary", "binding": "text.primary", "labelKey": "controlTextPrimary", "paletteStrategies": ["adaptive", "custom"] },
    { "id": "text.secondary", "group": "color", "type": "color", "source": "style.text.secondary", "binding": "text.secondary", "labelKey": "controlTextSecondary", "paletteStrategies": ["adaptive", "custom"] },
    { "id": "interaction.accent", "group": "color", "type": "color", "source": "style.interaction.accent", "binding": "interaction.accent", "labelKey": "controlAccent", "paletteStrategies": ["adaptive", "custom"] },
    { "id": "border.default", "group": "color", "type": "color", "source": "style.border.default", "binding": "border.default", "labelKey": "controlBorder", "paletteStrategies": ["adaptive", "custom"] },
    { "id": "typography.ui", "group": "typography", "type": "fontList", "source": "style.typography.ui", "binding": "typography.ui", "themePath": "fonts.ui", "labelKey": "controlFontUi" },
    { "id": "typography.display", "group": "typography", "type": "fontList", "source": "style.typography.display", "binding": "typography.display", "themePath": "fonts.display", "labelKey": "controlFontDisplay" },
    { "id": "typography.code", "group": "typography", "type": "fontList", "source": "style.typography.code", "binding": "typography.code", "themePath": "fonts.code", "labelKey": "controlFontCode" },
    { "id": "media.interactiveScrim", "group": "opacity", "type": "number", "source": "style.media.interactiveScrim", "binding": "media.interactiveScrim", "themePath": "interactiveBackground.scrimOpacity", "labelKey": "controlScrimOpacity", "minimum": 0, "maximum": 0.8, "step": 0.01, "unit": "" },
    { "id": "media.backgroundScrimOpacity", "group": "opacity", "type": "number", "source": "style.media.backgroundScrimOpacity", "binding": "media.backgroundScrimOpacity", "labelKey": "controlBackgroundOpacity", "minimum": 0, "maximum": 1, "step": 0.01, "unit": "" },
    { "id": "media.backgroundPosition", "group": "background", "type": "position", "source": "style.media.backgroundPosition", "bindings": ["media.backgroundX", "media.backgroundY"], "themePath": "appearance.backgroundPosition", "labelKey": "controlBackgroundPosition", "minimum": 0, "maximum": 100, "step": 1, "unit": "%" },
    { "id": "media.blur", "group": "background", "type": "number", "source": "style.media.blur", "binding": "media.blur", "themePath": "appearance.backdropBlurPx", "labelKey": "controlBlur", "minimum": 0, "maximum": 48, "step": 1, "unit": "px" },
    { "id": "media.saturation", "group": "background", "type": "number", "source": "style.media.saturation", "binding": "media.saturation", "themePath": "appearance.backdropSaturation", "labelKey": "controlSaturation", "minimum": 0.5, "maximum": 1.5, "step": 0.05, "unit": "" }
  ],
  "bindings": [
