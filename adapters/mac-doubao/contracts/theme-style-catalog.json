{
  "kind": "theme.style-catalog",
  "schemaVersion": 1,
  "catalogVersion": 4,
  "adapterId": "mac-doubao",
  "adapterVersion": "2.19.9",
  "adapterReleaseRevision": 4,
  "catalogId": "mac-doubao-theme",
  "geometryPolicy": "native",
  "description": "Unified Theme media and structural translucency for Doubao. immersive-scene-v1 additionally owns bounded role-based scene frames and readable text paint for its documented surfaces; its exact profile claim is limited to that paint/frame scope. Native font metrics, icons, control behavior, focus, geometry, and motion remain host-owned.",
  "groups": [
    { "id": "foundation" },
    { "id": "navigation" },
    { "id": "content" },
    { "id": "media" }
  ],
  "settingsControls": [],
  "bindings": [
    {
      "id": "foundation.surfaceBase",
      "group": "foundation",
      "cssVariable": "--cc-doubao-theme-surface-base",
      "source": "semanticColors.surfaceBase",
      "roles": ["background-fallback", "video-scrim"],
      "fidelity": "adaptive-tint-or-system-neutral"
    },
    {
      "id": "foundation.surfaceRaised",
      "group": "foundation",
      "cssVariable": "--cc-doubao-theme-surface-raised",
      "source": "semanticColors.surfaceRaised",
      "roles": ["right-side"],
      "fidelity": "adaptive-tint-or-system-neutral"
    },
    {
      "id": "navigation.sidebar",
      "group": "navigation",
      "cssVariable": "--cc-doubao-theme-sidebar-surface",
      "source": "semanticColors.sidebarSurface",
      "roles": ["sidebar"],
      "fidelity": "adaptive-tint-or-system-neutral"
    },
    {
      "id": "navigation.header",
      "group": "navigation",
      "cssVariable": "--cc-doubao-theme-header-surface",
      "source": "semanticColors.headerSurface",
      "roles": ["header-surface"],
      "fidelity": "adaptive-tint-or-system-neutral"
    },
    {
      "id": "content.scrimStart",
      "group": "content",
      "cssVariable": "--cc-doubao-theme-main-scrim-start",
      "source": "semanticColors.mainScrimStart",
      "roles": ["shell"],
      "fidelity": "adaptive-tint-or-system-neutral"
    },
    {
      "id": "content.scrimMid",
      "group": "content",
      "cssVariable": "--cc-doubao-theme-main-scrim-mid",
      "source": "semanticColors.mainScrimMid",
      "roles": ["shell"],
      "fidelity": "adaptive-tint-or-system-neutral"
    },
    {
      "id": "content.scrimEnd",
      "group": "content",
      "cssVariable": "--cc-doubao-theme-main-scrim-end",
      "source": "semanticColors.mainScrimEnd",
      "roles": ["shell"],
      "fidelity": "adaptive-tint-or-system-neutral"
    },
    {
      "id": "media.blur",
      "group": "media",
      "cssVariable": "--cc-doubao-backdrop-blur",
      "source": "appearance.backdropBlurPx",
      "roles": ["sidebar", "header-surface", "right-side"],
      "fidelity": "exact"
    },
    {
      "id": "media.saturation",
      "group": "media",
      "cssVariable": "--cc-doubao-saturation",
      "source": "appearance.backdropSaturation",
      "roles": ["sidebar", "header-surface", "right-side"],
      "fidelity": "exact"
    }
  ],
  "nativeOwned": [
    "text",
    "typography",
    "icons",
    "control-backgrounds",
    "hover-and-pressed-states",
    "selected-state-interaction",
    "composer-boundary-and-focus",
    "suggestion-cards",
    "dialog-and-popover-controls-and-interaction",
    "borders-and-shadows",
    "animations-and-transitions",
    "geometry"
  ]
}
