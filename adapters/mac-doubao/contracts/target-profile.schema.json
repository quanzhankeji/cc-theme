{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-theme.local/contracts/mac-doubao-target-profile.schema.json",
  "title": "Mac Doubao CC Theme target profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "adapterId", "values"],
  "properties": {
    "kind": { "const": "cc-theme.target-profile" },
    "schemaVersion": { "const": 1 },
    "adapterId": { "const": "mac-doubao" },
    "values": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "paletteStrategy": { "enum": ["system", "adaptive"] }
      }
    }
  }
}
