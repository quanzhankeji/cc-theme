{
  "kind": "theme.style-catalog",
  "schemaVersion": 1,
  "catalogVersion": 1,
  "catalogId": "win-workbuddy-theme",
  "verificationStatus": "static-only",
  "geometryPolicy": "native",
  "description": "Paint-only Windows bindings for the fixed interpreter. Host role bindings remain blocked until VM verification.",
  "groups": [
    { "id": "theme" },
    { "id": "palette" },
    { "id": "background" },
    { "id": "color" },
    { "id": "typography" },
    { "id": "appearance" }
  ],
  "settingsContract": {
    "route": "settings/cc-theme",
    "immediatePreview": true,
    "autoSave": true,
    "saveButton": false,
    "debounceMs": 180,
    "ordering": "monotonic-revision-latest-write-wins",
    "persistence": "atomic-port",
    "failure": "rollback-controls-renderer-and-disk"
  },
  "settingsControls": [
    { "id": "theme.selection", "group": "theme", "type": "theme", "source": "theme.id", "immediate": true },
    { "id": "palette.strategy", "group": "palette", "type": "select", "source": "appearance.paletteStrategy", "options": ["system", "adaptive", "custom"], "immediate": true },
    { "id": "background.presentation", "group": "background", "type": "select", "source": "runtime.backgroundPresentation", "options": ["enabled", "paused", "disabled"], "immediate": true },
    { "id": "color.surfaceBase", "group": "color", "type": "color", "source": "colors.surfaceBase", "paletteStrategies": ["adaptive", "custom"] },
    { "id": "color.surfaceRaised", "group": "color", "type": "color", "source": "colors.surfaceRaised", "paletteStrategies": ["adaptive", "custom"] },
    { "id": "color.surfaceElevated", "group": "color", "type": "color", "source": "colors.surfaceElevated", "paletteStrategies": ["adaptive", "custom"] },
    { "id": "color.text", "group": "color", "type": "color", "source": "colors.text", "paletteStrategies": ["adaptive", "custom"] },
    { "id": "color.textMuted", "group": "color", "type": "color", "source": "colors.textMuted", "paletteStrategies": ["adaptive", "custom"] },
    { "id": "color.action", "group": "color", "type": "color", "source": "colors.action", "paletteStrategies": ["adaptive", "custom"] },
    { "id": "color.borderDefault", "group": "color", "type": "color", "source": "colors.borderDefault", "paletteStrategies": ["adaptive", "custom"] },
    { "id": "font.ui", "group": "typography", "type": "fontList", "source": "fonts.ui" },
    { "id": "font.display", "group": "typography", "type": "fontList", "source": "fonts.display" },
    { "id": "font.code", "group": "typography", "type": "fontList", "source": "fonts.code" },
    { "id": "appearance.backdropBlurPx", "group": "appearance", "type": "number", "source": "appearance.backdropBlurPx", "minimum": 0, "maximum": 48 },
    { "id": "appearance.backdropSaturation", "group": "appearance", "type": "number", "source": "appearance.backdropSaturation", "minimum": 0.5, "maximum": 1.5 },
    { "id": "appearance.radiusScale", "group": "appearance", "type": "number", "source": "appearance.radiusScale", "minimum": 0.75, "maximum": 1.5 }
  ],
  "bindings": [
    { "id": "surfaceBase", "source": "colors.surfaceBase", "runtimeVariable": "--cc-wb-surface-base", "roles": ["shell"], "runtimeStatus": "unverified" },
    { "id": "surfaceRaised", "source": "colors.surfaceRaised", "runtimeVariable": "--cc-wb-surface-raised", "roles": ["surface-raised"], "runtimeStatus": "unverified" },
    { "id": "surfaceElevated", "source": "colors.surfaceElevated", "runtimeVariable": "--cc-wb-surface-elevated", "roles": ["surface-elevated"], "runtimeStatus": "unverified" },
    { "id": "surfaceCode", "source": "colors.surfaceCode", "runtimeVariable": "--cc-wb-surface-code", "roles": ["code-surface"], "runtimeStatus": "unverified" },
    { "id": "text", "source": "colors.text", "runtimeVariable": "--cc-wb-text", "roles": ["text-primary"], "runtimeStatus": "unverified" },
    { "id": "textStrong", "source": "colors.textStrong", "runtimeVariable": "--cc-wb-text-strong", "roles": ["text-strong"], "runtimeStatus": "unverified" },
    { "id": "textMuted", "source": "colors.textMuted", "runtimeVariable": "--cc-wb-text-muted", "roles": ["text-muted"], "runtimeStatus": "unverified" },
    { "id": "placeholder", "source": "colors.placeholder", "runtimeVariable": "--cc-wb-placeholder", "roles": ["input-placeholder"], "runtimeStatus": "unverified" },
    { "id": "borderSubtle", "source": "colors.borderSubtle", "runtimeVariable": "--cc-wb-border-subtle", "roles": ["border-subtle"], "runtimeStatus": "unverified" },
    { "id": "borderDefault", "source": "colors.borderDefault", "runtimeVariable": "--cc-wb-border-default", "roles": ["border-default"], "runtimeStatus": "unverified" },
    { "id": "borderStrong", "source": "colors.borderStrong", "runtimeVariable": "--cc-wb-border-strong", "roles": ["border-strong"], "runtimeStatus": "unverified" },
    { "id": "action", "source": "colors.action", "runtimeVariable": "--cc-wb-action", "roles": ["action"], "runtimeStatus": "unverified" },
    { "id": "actionHover", "source": "colors.actionHover", "runtimeVariable": "--cc-wb-action-hover", "roles": ["action"], "runtimeStatus": "unverified" },
    { "id": "actionPressed", "source": "colors.actionPressed", "runtimeVariable": "--cc-wb-action-pressed", "roles": ["action"], "runtimeStatus": "unverified" },
    { "id": "actionForeground", "source": "colors.actionForeground", "runtimeVariable": "--cc-wb-action-foreground", "roles": ["action"], "runtimeStatus": "unverified" },
    { "id": "hoverSurface", "source": "colors.hoverSurface", "runtimeVariable": "--cc-wb-hover-surface", "roles": ["interactive-surface"], "runtimeStatus": "unverified" },
    { "id": "pressedSurface", "source": "colors.pressedSurface", "runtimeVariable": "--cc-wb-pressed-surface", "roles": ["interactive-surface"], "runtimeStatus": "unverified" },
    { "id": "selectedSurface", "source": "colors.selectedSurface", "runtimeVariable": "--cc-wb-selected-surface", "roles": ["selected-surface"], "runtimeStatus": "unverified" },
    { "id": "selectedHoverSurface", "source": "colors.selectedHoverSurface", "runtimeVariable": "--cc-wb-selected-hover-surface", "roles": ["selected-surface"], "runtimeStatus": "unverified" },
    { "id": "focusRing", "source": "colors.focusRing", "runtimeVariable": "--cc-wb-focus-ring", "roles": ["focus-ring"], "runtimeStatus": "unverified" },
    { "id": "link", "source": "colors.link", "runtimeVariable": "--cc-wb-link", "roles": ["link"], "runtimeStatus": "unverified" },
    { "id": "danger", "source": "colors.danger", "runtimeVariable": "--cc-wb-danger", "roles": ["danger"], "runtimeStatus": "unverified" },
    { "id": "success", "source": "colors.success", "runtimeVariable": "--cc-wb-success", "roles": ["success"], "runtimeStatus": "unverified" },
    { "id": "warning", "source": "colors.warning", "runtimeVariable": "--cc-wb-warning", "roles": ["warning"], "runtimeStatus": "unverified" },
    { "id": "sidebarSurface", "source": "colors.sidebarSurface", "runtimeVariable": "--cc-wb-sidebar-surface", "roles": ["sidebar"], "runtimeStatus": "unverified" },
    { "id": "headerSurface", "source": "colors.headerSurface", "runtimeVariable": "--cc-wb-header-surface", "roles": ["header"], "runtimeStatus": "unverified" },
    { "id": "mainScrimStart", "source": "colors.mainScrimStart", "runtimeVariable": "--cc-wb-main-scrim-start", "roles": ["main-scrim"], "runtimeStatus": "unverified" },
    { "id": "mainScrimMid", "source": "colors.mainScrimMid", "runtimeVariable": "--cc-wb-main-scrim-mid", "roles": ["main-scrim"], "runtimeStatus": "unverified" },
    { "id": "mainScrimEnd", "source": "colors.mainScrimEnd", "runtimeVariable": "--cc-wb-main-scrim-end", "roles": ["main-scrim"], "runtimeStatus": "unverified" },
    { "id": "composerSurface", "source": "colors.composerSurface", "runtimeVariable": "--cc-wb-composer-surface", "roles": ["composer"], "runtimeStatus": "unverified" },
    { "id": "fontUi", "source": "fonts.ui", "runtimeVariable": "--cc-wb-font-ui", "roles": ["shell"], "runtimeStatus": "unverified" },
    { "id": "fontDisplay", "source": "fonts.display", "runtimeVariable": "--cc-wb-font-display", "roles": ["display-text"], "runtimeStatus": "unverified" },
    { "id": "fontCode", "source": "fonts.code", "runtimeVariable": "--cc-wb-font-code", "roles": ["code-text"], "runtimeStatus": "unverified" },
    { "id": "backdropBlurPx", "source": "appearance.backdropBlurPx", "runtimeVariable": "--cc-wb-backdrop-blur", "roles": ["overlay"], "runtimeStatus": "unverified" },
    { "id": "backdropSaturation", "source": "appearance.backdropSaturation", "runtimeVariable": "--cc-wb-backdrop-saturation", "roles": ["overlay"], "runtimeStatus": "unverified" },
    { "id": "radiusScale", "source": "appearance.radiusScale", "runtimeVariable": "--cc-wb-radius-scale", "roles": ["shell"], "runtimeStatus": "unverified" }
  ]
}
