{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-theme.local/contracts/win-workbuddy-skin-theme.schema.json",
  "title": "Windows WorkBuddy normalized skin theme",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "adapterId", "id", "name", "sourceVersion", "colors", "fonts", "appearance", "background", "accessibility"],
  "properties": {
    "kind": { "const": "skin.theme" },
    "schemaVersion": { "const": 1 },
    "adapterId": { "const": "win-workbuddy-skin" },
    "id": { "$ref": "#/$defs/safeId" },
    "name": { "type": "string", "minLength": 1, "maxLength": 80 },
    "sourceVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[A-Za-z0-9.-]+)?$", "maxLength": 40 },
    "colors": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/color" },
      "required": ["surfaceBase", "text", "textMuted", "action", "actionForeground", "focusRing"],
      "propertyNames": { "enum": ["surfaceBase", "surfaceRaised", "surfaceElevated", "surfaceCode", "text", "textStrong", "textMuted", "placeholder", "borderSubtle", "borderDefault", "borderStrong", "action", "actionHover", "actionPressed", "actionForeground", "hoverSurface", "pressedSurface", "selectedSurface", "selectedHoverSurface", "focusRing", "link", "danger", "success", "warning", "sidebarSurface", "headerSurface", "mainScrimStart", "mainScrimMid", "mainScrimEnd", "composerSurface"] }
    },
    "fonts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ui": { "$ref": "#/$defs/fontList" },
        "display": { "$ref": "#/$defs/fontList" },
        "code": { "$ref": "#/$defs/fontList" }
      }
    },
    "appearance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["paletteStrategy"],
      "properties": {
        "paletteStrategy": { "enum": ["system", "adaptive", "custom"] },
        "shellMode": { "enum": ["auto", "light", "dark"] },
        "backdropBlurPx": { "type": "number", "minimum": 0, "maximum": 48 },
        "backdropSaturation": { "type": "number", "minimum": 0.5, "maximum": 1.5 },
        "radiusScale": { "type": "number", "minimum": 0.75, "maximum": 1.5 },
        "backgroundPosition": { "$ref": "#/$defs/position" }
      }
    },
    "background": {
      "oneOf": [
        { "$ref": "#/$defs/mediaBackground" },
        { "$ref": "#/$defs/rippleBackground" },
        { "$ref": "#/$defs/directionalBackground" }
      ]
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reducedMotion"],
      "properties": {
        "reducedMotion": { "const": "static" },
        "preserveSystemFocusRing": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "safeId": { "type": "string", "pattern": "^[A-Za-z0-9_-]{1,80}$" },
    "color": { "type": "string", "pattern": "^(#[0-9A-Fa-f]{6}|rgba?\\([0-9., %]+\\))$", "maxLength": 48 },
    "fontList": { "type": "array", "minItems": 1, "maxItems": 8, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 80, "pattern": "^[A-Za-z0-9 ._-]+$" } },
    "localImage": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*\\.(png|jpe?g|webp)$", "minLength": 5, "maxLength": 255 },
    "localVideo": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*\\.mp4$", "minLength": 5, "maxLength": 255 },
    "staticWebp": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*\\.webp$", "minLength": 6, "maxLength": 255 },
    "position": { "type": "object", "additionalProperties": false, "required": ["xPercent", "yPercent"], "properties": { "xPercent": { "type": "number", "minimum": 0, "maximum": 100 }, "yPercent": { "type": "number", "minimum": 0, "maximum": 100 } } },
    "baseBackground": { "type": "object", "required": ["mode", "image"], "properties": { "image": { "$ref": "#/$defs/localImage" }, "scrimOpacity": { "type": "number", "minimum": 0, "maximum": 0.8 }, "position": { "$ref": "#/$defs/position" } } },
    "mediaBackground": { "allOf": [{ "$ref": "#/$defs/baseBackground" }, { "type": "object", "additionalProperties": false, "required": ["mode", "image"], "properties": { "mode": { "const": "media" }, "image": { "$ref": "#/$defs/localImage" }, "video": { "$ref": "#/$defs/localVideo" }, "posterMode": { "enum": ["none", "image"] }, "scrimOpacity": { "type": "number", "minimum": 0, "maximum": 0.8 }, "position": { "$ref": "#/$defs/position" } } }] },
    "rippleBackground": { "allOf": [{ "$ref": "#/$defs/baseBackground" }, { "type": "object", "additionalProperties": false, "required": ["mode", "image"], "properties": { "mode": { "const": "ripple" }, "image": { "$ref": "#/$defs/localImage" }, "intensity": { "type": "number", "minimum": 0, "maximum": 1 }, "radiusPx": { "type": "number", "minimum": 8, "maximum": 96 }, "quality": { "enum": ["auto", "low", "high"] }, "scrimOpacity": { "type": "number", "minimum": 0, "maximum": 0.8 }, "position": { "$ref": "#/$defs/position" } } }] },
    "directionalBackground": { "allOf": [{ "$ref": "#/$defs/baseBackground" }, { "type": "object", "additionalProperties": false, "required": ["mode", "image", "atlas", "directions", "columns", "rows"], "properties": { "mode": { "const": "directional" }, "image": { "$ref": "#/$defs/localImage" }, "atlas": { "$ref": "#/$defs/staticWebp" }, "directions": { "enum": [8, 16, 32] }, "columns": { "type": "integer", "minimum": 1, "maximum": 8 }, "rows": { "type": "integer", "minimum": 1, "maximum": 8 }, "firstDirectionDegrees": { "type": "number", "minimum": -180, "maximum": 180 }, "idleFrame": { "type": "integer", "minimum": 0, "maximum": 31 }, "origin": { "$ref": "#/$defs/position" }, "scrimOpacity": { "type": "number", "minimum": 0, "maximum": 0.8 }, "position": { "$ref": "#/$defs/position" } } }] }
  }
}
