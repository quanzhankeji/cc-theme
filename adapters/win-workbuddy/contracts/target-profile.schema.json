{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-theme.local/contracts/win-workbuddy-target-profile.schema.json",
  "title": "Windows WorkBuddy CC Theme target profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "adapterId", "values"],
  "properties": {
    "kind": { "const": "cc-theme.target-profile" },
    "schemaVersion": { "const": 1 },
    "adapterId": { "const": "win-workbuddy-skin" },
    "values": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "paletteStrategy": { "enum": ["system", "adaptive", "custom"] },
        "backgroundVideoPosterMode": { "enum": ["none", "image"] },
        "backgroundVideoPosition": { "$ref": "#/$defs/position" }
      }
    }
  },
  "$defs": {
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["xPercent", "yPercent"],
      "properties": {
        "xPercent": { "type": "number", "minimum": 0, "maximum": 100 },
        "yPercent": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    }
  }
}
