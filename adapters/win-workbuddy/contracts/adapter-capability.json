  "targetProfile": {
    "kind": "cc-theme.target-profile",
    "schema": "contracts/target-profile.schema.json",
    "schemaVersion": 1,
    "fields": [
      { "id": "paletteStrategy", "decision": "exact", "values": ["system", "adaptive", "custom"] },
      { "id": "backgroundVideoPosterMode", "decision": "exact", "values": ["none", "image"] },
      { "id": "backgroundVideoPosition", "decision": "exact", "type": "position" }
    ]
  },
  "paletteStrategy": {
    "precedence": ["shared-core", "target-profile", "local-runtime-override", "runtime-accessibility-and-host-safety"],
    "system": "Retain Shared Core colors as validated intent but use verified native Windows WorkBuddy colors as the active base; live behavior is currently unverified.",
    "adaptive": "Use Shared Core colors as the projected base and allow only catalog tokens to override them; authoring and live behavior are currently unverified.",
    "custom": "Use Shared Core colors as projected initial values, then namespaced Target Profile and allowlisted local overrides; live behavior is currently unverified.",
    "adaptiveAuthoringAvailable": false,
    "adaptiveRuntimeAvailable": false
  },
  "localRuntimeOverrides": {
    "kind": "theme.runtime-settings",
    "schema": "contracts/theme-runtime-settings.schema.json",
    "schemaVersion": 1,
    "catalog": "contracts/theme-style-catalog.json",
    "catalogVersion": 1,
    "rebase": "validate-by-stable-token-and-control-fingerprint",
    "incompatible": "quarantine-with-visible-diagnostic"
  },
  "transactionSeam": {
    "implementation": "src/lifecycle.mjs",
    "identityContract": "contracts/transaction-identity.json",
    "scope": "theme-id",
    "serialization": "required-not-yet-live",
    "persistence": "atomic-port-required",
    "writers": ["manager-apply", "workbuddy-settings"],
    "verificationStatus": "unverified",
    "runtimeOrdering": { "field": "rendererGeneration", "scope": "renderer-session" },
    "artifactIdentity": { "field": "artifactManifestSha256", "algorithm": "sha256", "scope": "deterministic-runtime-manifest" },
    "orderingAndArtifactIdentityAreDistinct": true
  },
  "migration": {
    "writePolicy": "new writes use Unified Theme v2 plus namespaced Target Profile",
    "legacyMacImplementation": "never-used"
  }
}
