      { "source": "accessibility.minimumLargeTextContrast", "decision": "unsupported", "required": false, "target": null, "diagnostic": "contrast-audit-unavailable" },
      { "source": "accessibility.preserveSystemFocusRing", "decision": "approximate", "required": false, "target": "accessibility.preserveSystemFocusRing", "diagnostic": "focus-ring-host-parity-pending", "condition": "target value is retained; live native parity remains gated" },
