{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-theme.local/win-claude/host-evidence.schema.json",
  "title": "Win-Claude host evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "adapterId", "evidenceClass", "capturedDate", "provenance", "client", "identityAnchors", "remoteDebuggingGate", "officialDeveloperTools", "privacy", "conclusion"],
  "properties": {
    "kind": { "const": "cc-theme.windows-claude-host-evidence" },
    "schemaVersion": { "const": 1 },
    "adapterId": { "const": "win-claude" },
    "evidenceClass": { "enum": ["vm-verified", "static-analysis", "unverified"] },
    "capturedDate": { "type": "string", "format": "date" },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verifierRole", "methods"],
      "properties": {
        "verifierRole": { "const": "win-lead" },
        "methods": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 120 } }
      }
    },
    "client": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "packageForm", "distribution", "architecture", "publisher", "signatureStatus", "packageMain"],
      "properties": {
        "version": { "const": "1.22209.0" },
        "packageForm": { "const": "msix" },
        "distribution": { "const": "microsoft-store" },
        "architecture": { "const": "arm64" },
        "publisher": { "const": "Anthropic" },
        "signatureStatus": { "const": "valid" },
        "packageMain": { "const": ".vite/build/index.pre.js" }
      }
    },
    "identityAnchors": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packageFullName", "packageFamilyName", "signerSubject", "binarySha256", "futureAllowlistReady", "missing"],
      "properties": {
        "packageFullName": { "type": ["string", "null"], "maxLength": 200 },
        "packageFamilyName": { "type": ["string", "null"], "maxLength": 160 },
        "signerSubject": { "type": ["string", "null"], "maxLength": 240 },
        "binarySha256": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" },
        "futureAllowlistReady": { "const": false },
        "missing": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["package-full-name", "package-family-name", "signer-subject", "binary-sha256"] } }
      }
    },
    "remoteDebuggingGate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["portBlockedWithoutOfficialAuth", "pipeBlockedWithoutOfficialAuth", "requiredEnvironmentNames", "tokenSegments", "boundToUserDataDirectory", "freshnessSeconds", "signatureAlgorithm", "verificationKeyOwner", "adapterBypassPolicy"],
      "properties": {
        "portBlockedWithoutOfficialAuth": { "const": true },
        "pipeBlockedWithoutOfficialAuth": { "const": true },
        "requiredEnvironmentNames": { "const": ["CLAUDE_CDP_AUTH", "CLAUDE_USER_DATA_DIR"] },
        "tokenSegments": { "const": 3 },
        "boundToUserDataDirectory": { "const": true },
        "freshnessSeconds": { "const": 300 },
        "signatureAlgorithm": { "const": "ed25519" },
        "verificationKeyOwner": { "const": "Anthropic" },
        "adapterBypassPolicy": { "const": "forbidden" }
      }
    },
    "officialDeveloperTools": {
      "type": "object",
      "additionalProperties": false,
      "required": ["environmentName", "value", "codePathObserved", "platformRestrictionObserved", "allowedUse", "productionTransport"],
      "properties": {
        "environmentName": { "const": "CLAUDE_DEV_TOOLS" },
        "value": { "const": "detach" },
        "codePathObserved": { "const": true },
        "platformRestrictionObserved": { "const": false },
        "allowedUse": { "const": "manual-disposable-proof-only" },
        "productionTransport": { "const": false }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authenticationTokenStored", "commandLineStored", "environmentDumpStored", "fullUserPathStored", "rawAsarStored"],
      "properties": {
        "authenticationTokenStored": { "const": false },
        "commandLineStored": { "const": false },
        "environmentDumpStored": { "const": false },
        "fullUserPathStored": { "const": false },
        "rawAsarStored": { "const": false }
      }
    },
    "conclusion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clientIdentityVerified", "productionRuntimeSeamVerified", "runtimeApplyAvailable", "reasonCode", "blockers"],
      "properties": {
        "clientIdentityVerified": { "const": true },
        "productionRuntimeSeamVerified": { "const": false },
        "runtimeApplyAvailable": { "const": false },
        "reasonCode": { "const": "production-runtime-seam-unverified" },
        "blockers": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z0-9-]+$" } }
      }
    }
  }
}
